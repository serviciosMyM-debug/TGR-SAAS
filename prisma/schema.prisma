generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPERADMIN
  ADMIN
  FACTURACION
  OPERACIONES
  VISOR
}

enum BudgetType {
  DOMICILIARIO
  COMERCIAL
  INDUSTRIAL
  COMIENZO_DE_OBRA
  CORRIENTES_DEBILES
}

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  ARCHIVED
}

enum InvoiceStatus {
  DRAFT
  EMITTED
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum MovementType {
  INCOME
  EXPENSE
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
  CHECK
  ACCOUNT
  OTHER
}

enum CatalogUnitType {
  UNIT
  EVERY_5_METERS
}

model User {
  id             String      @id @default(cuid())
  name           String
  email          String      @unique
  passwordHash   String
  role           UserRole    @default(ADMIN)
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  auditLogs      AuditLog[]
  quotesCreated  Quote[]     @relation("QuoteCreatedBy")
  invoicesIssued Invoice[]   @relation("InvoiceIssuedBy")
}

model Client {
  id                String      @id @default(cuid())
  businessName      String
  contactName       String?
  taxId             String?
  email             String?
  phone             String?
  address           String?
  city              String?
  notes             String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  quotes            Quote[]
  invoices          Invoice[]
  projects          Project[]
  financialMovements FinancialMovement[]
}

model CatalogItem {
  id          String          @id @default(cuid())
  code        String          @unique
  title       String
  description String?
  budgetType  BudgetType?
  category    String?
  unitType    CatalogUnitType @default(UNIT)
  unitLabel   String?         @default("u")
  basePrice   Decimal         @db.Decimal(12, 2)
  isActive    Boolean         @default(true)
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  quoteItems  QuoteItem[]
}

model Quote {
  id                 String      @id @default(cuid())
  number             Int         @unique @default(autoincrement())
  budgetType         BudgetType
  title              String
  projectDescription String?
  contactName        String?
  contactPhone       String?
  address            String?
  observations       String?
  laborDescription   String?
  executionStages    String?
  discountPercent    Decimal     @default(0) @db.Decimal(5, 2)
  subtotal           Decimal     @default(0) @db.Decimal(12, 2)
  discountAmount     Decimal     @default(0) @db.Decimal(12, 2)
  total              Decimal     @default(0) @db.Decimal(12, 2)
  status             QuoteStatus @default(DRAFT)
  issuedAt           DateTime    @default(now())
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  clientId           String?
  createdById        String?
  client             Client?     @relation(fields: [clientId], references: [id])
  createdBy          User?       @relation("QuoteCreatedBy", fields: [createdById], references: [id])
  items              QuoteItem[]
  invoice            Invoice?
}

model QuoteItem {
  id            String   @id @default(cuid())
  quoteId       String
  catalogItemId String?
  itemCode      String?
  title         String
  description   String?
  quantity      Decimal  @default(1) @db.Decimal(12, 2)
  unitPrice     Decimal  @default(0) @db.Decimal(12, 2)
  lineTotal     Decimal  @default(0) @db.Decimal(12, 2)
  unitType      CatalogUnitType @default(UNIT)
  unitLabel     String?  @default("u")
  quote         Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  catalogItem   CatalogItem? @relation(fields: [catalogItemId], references: [id])
}

model Invoice {
  id              String        @id @default(cuid())
  number          Int           @unique @default(autoincrement())
  status          InvoiceStatus @default(EMITTED)
  issueDate       DateTime      @default(now())
  dueDate         DateTime?
  title           String
  notes           String?
  subtotal        Decimal       @default(0) @db.Decimal(12, 2)
  taxAmount       Decimal       @default(0) @db.Decimal(12, 2)
  total           Decimal       @default(0) @db.Decimal(12, 2)
  amountPaid      Decimal       @default(0) @db.Decimal(12, 2)
  paymentMethod   PaymentMethod?
  clientId        String?
  quoteId         String?       @unique
  issuedById      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  client          Client?       @relation(fields: [clientId], references: [id])
  quote           Quote?        @relation(fields: [quoteId], references: [id])
  issuedBy        User?         @relation("InvoiceIssuedBy", fields: [issuedById], references: [id])
  items           InvoiceItem[]
  payments        Payment[]
  movements       FinancialMovement[]
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  quantity    Decimal  @default(1) @db.Decimal(12, 2)
  unitPrice   Decimal  @default(0) @db.Decimal(12, 2)
  lineTotal   Decimal  @default(0) @db.Decimal(12, 2)
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Payment {
  id            String        @id @default(cuid())
  invoiceId      String
  amount         Decimal       @db.Decimal(12, 2)
  paymentMethod  PaymentMethod @default(TRANSFER)
  paidAt         DateTime      @default(now())
  reference      String?
  notes          String?
  createdAt      DateTime      @default(now())
  invoice        Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model ExpenseCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  movements FinancialMovement[]
}

model FinancialMovement {
  id               String        @id @default(cuid())
  type             MovementType
  title            String
  description      String?
  amount           Decimal       @db.Decimal(12, 2)
  movementDate     DateTime      @default(now())
  categoryLabel    String?
  paymentMethod    PaymentMethod?
  clientId         String?
  invoiceId        String?
  expenseCategoryId String?
  createdAt        DateTime      @default(now())
  client           Client?       @relation(fields: [clientId], references: [id])
  invoice          Invoice?      @relation(fields: [invoiceId], references: [id])
  expenseCategory  ExpenseCategory? @relation(fields: [expenseCategoryId], references: [id])
}

model Project {
  id          String   @id @default(cuid())
  title       String
  city        String?
  summary     String
  details     String?
  image       String?
  highlighted Boolean  @default(false)
  clientId    String?
  createdAt   DateTime @default(now())
  client      Client?  @relation(fields: [clientId], references: [id])
}

model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  entity      String
  entityId    String?
  payload     String?
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id])
}
